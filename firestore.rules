rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── Register app permission hierarchy ───────────────────────
    // schoolAdmin: full access within their own school.
    // teacherAdmin: only their assigned class(es) within their own school
    // (an empty/absent assignedClasses list means whole-school access, e.g. a deputy).
    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function myRole() {
      return myProfile().role;
    }
    function mySchoolId() {
      return myProfile().schoolId;
    }
    function myAssignedClasses() {
      return myProfile().get('assignedClasses', []);
    }
    function isSchoolAdminOf(schoolId) {
      return isSignedIn() && myRole() == 'schoolAdmin' && mySchoolId() == schoolId;
    }
    function isTeacherOf(schoolId, classCode) {
      return isSignedIn() && myRole() == 'teacherAdmin' && mySchoolId() == schoolId &&
        (myAssignedClasses().size() == 0 || classCode in myAssignedClasses());
    }
    // Any signed-in member (admin or teacher) of a school — used where access isn't class-scoped
    // (e.g. messaging, which can target a single class or the whole school).
    function isSchoolMember(schoolId) {
      return isSchoolAdminOf(schoolId) || (isSignedIn() && myRole() == 'teacherAdmin' && mySchoolId() == schoolId);
    }
    function hasClassAccess(schoolId, classCode) {
      return isSchoolAdminOf(schoolId) || isTeacherOf(schoolId, classCode);
    }

    match /phone_index/{phone} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    // Doc id = KNEC code. `resource == null` only when the code has never been
    // registered, so this also rejects a second school trying to claim the same code.
    match /schools/{schoolId} {
      // Public read: a prospective teacher looks a school up by its KNEC code (name, level,
      // boarding type) on the "Find School" step of signup, before they have an account.
      allow read: if true;
      allow write: if request.auth != null &&
        (resource == null || resource.data.adminUid == request.auth.uid);
    }
    // One classStructures doc per school (doc id = KNEC code). Only that school's admin may write.
    // NOTE: the `schools/{schoolId}` doc must exist (and have adminUid set to the caller) BEFORE
    // this write happens — see AuthContext.signUp, which now creates the school doc first.
    match /classStructures/{schoolId} {
      // Same public-read reasoning as `schools/{schoolId}` above — the class list is needed
      // for the pre-signup "Find School" lookup.
      allow read: if true;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/schools/$(schoolId)).data.adminUid == request.auth.uid;
    }
    // Doc id = `${schoolId}_${label}`. Only the owning school's admin may create/update; never deleted.
    // Same ordering requirement as classStructures above: `schools/{schoolId}` must exist first.
    match /academicYears/{yearId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null &&
        get(/databases/$(database)/documents/schools/$(request.resource.data.schoolId)).data.adminUid == request.auth.uid;
      allow delete: if false;
    }
    // Saved column-mapping preset per school for the bulk student importer (doc id = schoolId).
    match /importMappings/{schoolId} {
      allow read: if request.auth != null;
      allow write: if isSchoolAdminOf(schoolId);
    }
    match /students/{id} {
      // Read is school-wide (not class-scoped): a school-wide `where('schoolId','==',…)` query
      // must be provably valid for Firestore to run it at all for a class-restricted teacher,
      // and admission-number uniqueness has to be checked against the whole school roster, not
      // just one class. What a teacher can actually DO with a student outside their class is
      // still fully locked down below — only reads are broadened.
      allow read: if resource != null && isSchoolMember(resource.data.schoolId);
      allow create: if hasClassAccess(request.resource.data.schoolId, request.resource.data.classCode);
      // Update: need access via the class the student is currently in OR the class they're
      // moving to, so a transfer/internal-move by an authorised teacher/admin isn't blocked.
      allow update: if hasClassAccess(resource.data.schoolId, resource.data.classCode) ||
                       hasClassAccess(request.resource.data.schoolId, request.resource.data.classCode);
      allow delete: if false; // never delete a student record — preserves history
    }
    // References a student + academic year rather than being embedded on the student doc,
    // so a student can have one row per year without ever overwriting prior years.
    match /enrolments/{id} {
      allow read: if resource != null && isSchoolMember(resource.data.schoolId);
      allow create: if hasClassAccess(request.resource.data.schoolId, request.resource.data.classCode);
      allow update: if hasClassAccess(resource.data.schoolId, resource.data.classCode) ||
                       hasClassAccess(request.resource.data.schoolId, request.resource.data.classCode);
      allow delete: if false; // enrolments are closed out (status change), never deleted
    }
    match /attendance/{id} {
      allow read:   if hasClassAccess(resource.data.schoolId, resource.data.classCode);
      allow create: if hasClassAccess(request.resource.data.schoolId, request.resource.data.classCode);
      allow update: if hasClassAccess(resource.data.schoolId, resource.data.classCode);
      allow delete: if false; // attendance history is never deleted, including across transfers
    }
    match /registers/{id} {
      allow read:   if hasClassAccess(resource.data.schoolId, resource.data.classCode);
      allow create: if hasClassAccess(request.resource.data.schoolId, request.resource.data.classCode);
      allow update: if hasClassAccess(resource.data.schoolId, resource.data.classCode);
      allow delete: if false;
    }
    match /messages/{id} {
      allow read:   if resource != null && isSchoolMember(resource.data.schoolId);
      allow create: if isSchoolMember(request.resource.data.schoolId);
      allow update, delete: if false; // sent messages are an immutable log
    }
    // Immutable audit trail of every student transfer (in/out/internal/stream/cross-year).
    // Never updated or deleted — a reversal writes its own compensating record instead.
    match /transfers/{id} {
      allow read:   if resource != null && isSchoolMember(resource.data.schoolId);
      allow create: if isSchoolMember(request.resource.data.schoolId);
      allow update, delete: if false;
    }
    // A teacher's assignment to a single class. Only the school's admin may assign/unassign;
    // the teacher themself (or the school's admin) may read their own assignments.
    match /teacherAssignments/{id} {
      // Any signed-in user can read: the class-lock check (both at signup, before a class can
      // be claimed, and in the admin's Assignment Manager) needs to see who else already
      // teaches a class, not just the caller's own assignment. Assignment records aren't
      // sensitive — mirrors the same openness as `users/{userId}` read below.
      allow read: if isSignedIn();
      allow create: if isSchoolAdminOf(request.resource.data.schoolId) ||
        // Self-signup: a brand-new teacher account creating ITS OWN first assignment record
        // for the class it just claimed. `assignedBy == self` marks it as self-service so this
        // branch can never be used to plant an assignment for someone else.
        (isSignedIn() && myRole() == 'teacherAdmin' && mySchoolId() == request.resource.data.schoolId &&
         request.auth.uid == request.resource.data.teacherUid &&
         request.resource.data.assignedBy == request.auth.uid &&
         request.resource.data.active == true);
      // Admin can update (re-assign) at their own school. A teacher may ONLY deactivate their
      // own assignment (as part of a self-service school transfer) — never reactivate one,
      // touch anyone else's, or change which class/school it points to.
      allow update: if isSchoolAdminOf(request.resource.data.schoolId) ||
        (isSignedIn() && myRole() == 'teacherAdmin' && request.auth.uid == resource.data.teacherUid &&
         request.resource.data.active == false &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['active', 'endedAt', 'endedReason']));
      allow delete: if false; // assignments are deactivated (active:false), never deleted
    }
    // Immutable teacher transfer log (class/stream moves are admin-initiated at their own
    // school; a school transfer can ONLY be initiated by the teacher themself, on their own
    // account — admins can never move a teacher to another school).
    match /teacherTransfers/{id} {
      allow read: if resource != null &&
        (isSchoolAdminOf(resource.data.fromSchoolId) || request.auth.uid == resource.data.teacherUid);
      allow create: if
        (request.resource.data.type != 'school_transfer' &&
         isSchoolAdminOf(request.resource.data.fromSchoolId) &&
         get(/databases/$(database)/documents/users/$(request.resource.data.teacherUid)).data.role == 'teacherAdmin')
        ||
        (request.resource.data.type == 'school_transfer' &&
         isSignedIn() && myRole() == 'teacherAdmin' &&
         request.auth.uid == request.resource.data.teacherUid &&
         request.resource.data.performedBy == request.auth.uid);
      allow update, delete: if false;
    }
    // Global (not nested under a school) so a graduate can be looked up regardless of which
    // school they came from — e.g. an employer verifying attendance history. Publicly readable
    // by design; only the graduating school's admin can create it, and it's never editable or
    // deletable afterward, since it's a permanent record.
    match /archivedStudents/{id} {
      allow read: if true;
      allow create: if request.auth != null &&
        get(/databases/$(database)/documents/schools/$(request.resource.data.schoolId)).data.adminUid == request.auth.uid;
      allow update, delete: if false;
    }

    // ── users ────────────────────────────────────────────────
    // Any signed-in user can read profiles. A user can create/update only their own profile,
    // except a schoolAdmin may also update a teacherAdmin's profile within their own school
    // (needed for assigning/removing classes and teacher transfers).
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) ||
        (isSignedIn() && myRole() == 'schoolAdmin' && resource.data.schoolId == mySchoolId());
      allow delete: if false;
    }
  }
}
