rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
  function isSignedIn() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isInternal() {
      return isSignedIn() && userRole() == 'internal';
    }

    function isAdmin() {
      return isSignedIn() && userRole() in ['admin', 'internal'];
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── Register app permission hierarchy ───────────────────────
    // schoolAdmin: full access within their own school.
    // teacherAdmin: only their assigned class(es) within their own school
    // (an empty/absent assignedClasses list means whole-school access, e.g. a deputy).
    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function myRole() {
      return myProfile().role;
    }
    function mySchoolId() {
      return myProfile().schoolId;
    }
    function myAssignedClasses() {
      return myProfile().get('assignedClasses', []);
    }
    function isSchoolAdminOf(schoolId) {
      return isSignedIn() && myRole() == 'schoolAdmin' && mySchoolId() == schoolId;
    }
    function isTeacherOf(schoolId, classCode) {
      return isSignedIn() && myRole() == 'teacherAdmin' && mySchoolId() == schoolId &&
        (myAssignedClasses().size() == 0 || classCode in myAssignedClasses());
    }
    // Any signed-in member (admin or teacher) of a school — used where access isn't class-scoped
    // (e.g. messaging, which can target a single class or the whole school).
    function isSchoolMember(schoolId) {
      return isSchoolAdminOf(schoolId) || (isSignedIn() && myRole() == 'teacherAdmin' && mySchoolId() == schoolId);
    }
    function hasClassAccess(schoolId, classCode) {
      return isSchoolAdminOf(schoolId) || isTeacherOf(schoolId, classCode);
    }

    // ── users ────────────────────────────────────────────────
    // Any signed-in user can read profiles (needed for league tables,
    // fixture displays, etc.). Only the owner or an admin can write.
    match /users/{uid} {
      // allow read:   if isSignedIn();
      // allow create: if isOwner(uid) || isAdmin();
      // allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── leagues ──────────────────────────────────────────────
    // All signed-in users can read. Only admins/internal can mutate.
    match /leagues/{leagueId} {
      allow read:   if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isInternal();
    }

    // ── cups ─────────────────────────────────────────────────
    match /cups/{cupId} {
      allow read:   if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isInternal();
    }

    // ── fixtures ─────────────────────────────────────────────
    // Players may submit their own fixture results (update only,
    // and only the score fields). Full create/delete stays admin.
    match /fixtures/{fixtureId} {
      allow read:   if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin()
                    || (isSignedIn()
                        && (request.auth.uid == resource.data.home
                            || request.auth.uid == resource.data.away)
                        && request.resource.data.diff(resource.data)
                                             .affectedKeys()
                                             .hasOnly(['homeScore','awayScore','completed']));
      allow delete: if isInternal();
    }

    // ── careerStats ──────────────────────────────────────────
    // Public read for leaderboards. Owner or admin can write.
    match /careerStats/{uid} {
      allow read:   if isSignedIn();
      allow create: if isOwner(uid) || isAdmin();
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── seasonHistory ────────────────────────────────────────
    match /seasonHistory/{entryId} {
      allow read:   if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isInternal();
    }
    
    match /phone_index/{phone} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    // Doc id = KNEC code. `resource == null` only when the code has never been
    // registered, so this also rejects a second school trying to claim the same code.
    match /schools/{schoolId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        (resource == null || resource.data.adminUid == request.auth.uid);
    }
    // One classStructures doc per school (doc id = KNEC code). Only that school's admin may write.
    match /classStructures/{schoolId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/schools/$(schoolId)).data.adminUid == request.auth.uid;
    }
    // Doc id = `${schoolId}_${label}`. Only the owning school's admin may create/update; never deleted.
    match /academicYears/{yearId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null &&
        get(/databases/$(database)/documents/schools/$(request.resource.data.schoolId)).data.adminUid == request.auth.uid;
      allow delete: if false;
    }
    match /students/{id} {
      allow read: if hasClassAccess(resource.data.schoolId, resource.data.classCode);
      allow create: if hasClassAccess(request.resource.data.schoolId, request.resource.data.classCode);
      // Update: need access via the class the student is currently in OR the class they're
      // moving to, so a transfer/internal-move by an authorised teacher/admin isn't blocked.
      allow update: if hasClassAccess(resource.data.schoolId, resource.data.classCode) ||
                       hasClassAccess(request.resource.data.schoolId, request.resource.data.classCode);
      allow delete: if false; // never delete a student record — preserves history
    }
    // References a student + academic year rather than being embedded on the student doc,
    // so a student can have one row per year without ever overwriting prior years.
    match /enrolments/{id} {
      allow read: if hasClassAccess(resource.data.schoolId, resource.data.classCode);
      allow create: if hasClassAccess(request.resource.data.schoolId, request.resource.data.classCode);
      allow update: if hasClassAccess(resource.data.schoolId, resource.data.classCode) ||
                       hasClassAccess(request.resource.data.schoolId, request.resource.data.classCode);
      allow delete: if false; // enrolments are closed out (status change), never deleted
    }
    match /attendance/{id} {
      allow read:   if hasClassAccess(resource.data.schoolId, resource.data.classCode);
      allow create: if hasClassAccess(request.resource.data.schoolId, request.resource.data.classCode);
      allow update: if hasClassAccess(resource.data.schoolId, resource.data.classCode);
      allow delete: if false; // attendance history is never deleted, including across transfers
    }
    match /registers/{id} {
      allow read:   if hasClassAccess(resource.data.schoolId, resource.data.classCode);
      allow create: if hasClassAccess(request.resource.data.schoolId, request.resource.data.classCode);
      allow update: if hasClassAccess(resource.data.schoolId, resource.data.classCode);
      allow delete: if false;
    }
    match /messages/{id} {
      allow read:   if resource != null && isSchoolMember(resource.data.schoolId);
      allow create: if isSchoolMember(request.resource.data.schoolId);
      allow update, delete: if false; // sent messages are an immutable log
    }
    // Immutable audit trail of every student transfer (in/out/internal/stream/cross-year).
    // Never updated or deleted — a reversal writes its own compensating record instead.
    match /transfers/{id} {
      allow read:   if resource != null && isSchoolMember(resource.data.schoolId);
      allow create: if isSchoolMember(request.resource.data.schoolId);
      allow update, delete: if false;
    }
    // A teacher's assignment to a single class. Only the school's admin may assign/unassign;
    // the teacher themself (or the school's admin) may read their own assignments.
    match /teacherAssignments/{id} {
      allow read: if resource != null &&
        (isSchoolAdminOf(resource.data.schoolId) || request.auth.uid == resource.data.teacherUid);
      allow create: if isSchoolAdminOf(request.resource.data.schoolId);
      // Admin can update (re-assign) at their own school. A teacher may ONLY deactivate their
      // own assignment (as part of a self-service school transfer) — never reactivate one,
      // touch anyone else's, or change which class/school it points to.
      allow update: if isSchoolAdminOf(request.resource.data.schoolId) ||
        (isSignedIn() && myRole() == 'teacherAdmin' && request.auth.uid == resource.data.teacherUid &&
         request.resource.data.active == false &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['active', 'endedAt', 'endedReason']));
      allow delete: if false; // assignments are deactivated (active:false), never deleted
    }
    // Immutable teacher transfer log (class/stream moves are admin-initiated at their own
    // school; a school transfer can ONLY be initiated by the teacher themself, on their own
    // account — admins can never move a teacher to another school).
    match /teacherTransfers/{id} {
      allow read: if resource != null &&
        (isSchoolAdminOf(resource.data.fromSchoolId) || request.auth.uid == resource.data.teacherUid);
      allow create: if
        (request.resource.data.type != 'school_transfer' &&
         isSchoolAdminOf(request.resource.data.fromSchoolId) &&
         get(/databases/$(database)/documents/users/$(request.resource.data.teacherUid)).data.role == 'teacherAdmin')
        ||
        (request.resource.data.type == 'school_transfer' &&
         isSignedIn() && myRole() == 'teacherAdmin' &&
         request.auth.uid == request.resource.data.teacherUid &&
         request.resource.data.performedBy == request.auth.uid);
      allow update, delete: if false;
    }
    // Global (not nested under a school) so a graduate can be looked up regardless of which
    // school they came from — e.g. an employer verifying attendance history. Publicly readable
    // by design; only the graduating school's admin can create it, and it's never editable or
    // deletable afterward, since it's a permanent record.
    match /archivedStudents/{id} {
      allow read: if true;
      allow create: if request.auth != null &&
        get(/databases/$(database)/documents/schools/$(request.resource.data.schoolId)).data.adminUid == request.auth.uid;
      allow update, delete: if false;
    }

    // User data (roles, profiles, etc.)
    match /users/{userId} {
      // allow read: if request.auth.uid == userId || isAdmin(request.auth.uid) || request.auth.uid != null;
      // allow write: if request.auth.uid == userId || isSuperAdmin(request.auth.uid) || 
      //                 canAddUser(request.auth.uid, request.resource.data.role) || 
      //                 request.auth.uid != userId && request.resource.data.friendRequests.size() < 100;
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      // A teacherAdmin may only ever edit their own profile. A schoolAdmin may also edit a
      // teacherAdmin's profile within their own school (needed for assigning/removing classes
      // and teacher transfers, which update the target teacher's assignedClasses/schoolId).
      allow update: if isOwner(userId) ||
        (isSignedIn() && myRole() == 'schoolAdmin' && resource.data.schoolId == mySchoolId());
      allow delete: if false;
      //allow create: if request.auth != null;
//       function isAdmin(uid) {
//         return get(/databases/$(database)/documents/users/$(uid)).data.role in ['superAdmin', 'teacherAdmin', 'tuitionAdmin', 'schoolAdmin'];
//       }

//       function isSuperAdmin(uid) {
//         return get(/databases/$(database)/documents/users/$(uid)).data.role == 'superAdmin';
//       }

//       function canAddUser(uid, role) {
//         return (isSuperAdmin(uid) && role == 'superAdmin') || // Only superAdmin can add superAdmin
//                (isAdmin(uid) && role in ['student', 'parent']) || 
//                (get(/databases/$(database)/documents/users/$(uid)).data.role == 'schoolAdmin' && !(role in ['schoolAdmin', 'superAdmin', 'tuitionAdmin']));
//       }
    }
    
    match /chats/{chatId} {
        allow create, write, read: if request.auth != null;

        match /messages/{messageId} {
          allow read, write: if request.auth != null;
        }
      }
    
    // Public keys collection
    match /keys/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    
    match /users/{userId}/ratings/{ratingId} {
    	allow read, write: if request.auth != null;
    }
    
    match /notifications/{userId}/inbox/{notificationId} {
    	allow read, write: if request.auth != null;
    }
    
    
    match /users/{userId}/chunks/{chunkId} {
    	allow read, write: if request.auth != null;
    }
    
    match /users/{userId}/pals/{palId} {
    	allow read, write: if request.auth != null;
    }
    
    match /users/{userId}/palRequests/{id} {
    	allow read, write: if request.auth != null;
    }
    
    match /users/{userId}/subjects/{subjectId} {
      allow read, write: if request.auth != null;
    }
    
    match /rankings/topics/{topicId}/{userId} {
    	allow read, write: if request.auth != null;
    }

    match /subjects/{subjectId}/analytics/{topicId} {
      allow read, write: if request.auth != null;
    }

    match /rankings/subjects/{subjectId}/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    match /discussions/{discussionId} {
        allow read, write: if request.auth != null;
    }
    
    match /users/{userId}/subjectsAnalysis/{dateKey} {
        allow read, write: if request.auth != null;
    }
    
    match /users/{userId}/completedLessons/{id} {
        allow read, write: if request.auth != null;
    }
    
    match /users/{userId}/activity/tracking {
        allow read, write: if request.auth != null;
    }
    
    match /gamify/coinDonations {
        allow read, write: if request.auth != null;
    }
    
    match /users/{userId}/transactions/{id} {
        allow read, write: if request.auth != null;
    }
    
    match /users/{userId}/examHistory/{dateKey} {
        allow read, write: if request.auth != null;
    }
    
    match /subjects/{subjectId}/analysis/{dateKey} {
        allow read, write: if request.auth != null;
    }
    
    match /subjects/{subjectId}/certificates/{userUid} {
        allow read, write: if request.auth != null;
    }
    
    match /schools/{schoolId}/income/{incomeId} {
        allow read, write: if request.auth != null;
    }
    
    match /shops/{shopId} {
        allow read, write: if request.auth != null;
    }
    
    match /shops/{shopId}/products/{productId} {
        allow read, write: if request.auth != null;
    }
    
    match /donations/{donationsId} {
        allow read, write: if request.auth != null;
    }
    match /devices/{deviceId} {
        allow read, write: if request.auth != null;
    }
    
    match /users/{userId}/scores/{triviaId} {
      allow read, write: if request.auth != null; //&& request.auth.uid == userId;
    }
    
    match /users/{userId}/usage/{docId} {
      allow read, write: if request.auth != null; //&& request.auth.uid == userId;
    }
    
    match /users/{userId}/tests/{docId} {
      allow read, write: if request.auth != null; //&& request.auth.uid == userId;
    }
    
    match /users/{userId}/activity/lastActivity {
      allow read, write: if request.auth != null; //&& request.auth.uid == userId;
    }
    
    match /users/{userId}/bank/{bankId} {
      allow read, write: if request.auth != null; //&& request.auth.uid == userId;
    }
    
    match /users/{userId}/friends/{docId} {
      allow read, write: if request.auth != null; //&& request.auth.uid == userId;
    }
    
    match /users/{userId}/followers/{docId} {
      allow read, write: if request.auth != null; //&& request.auth.uid == userId;
    }
    
    match /users/{userId}/following/{docId} {
      allow read, write: if request.auth != null; //&& request.auth.uid == userId;
    }
    
    match /stories/{storyId} {
        allow read, write: if request.auth != null;
    }
    
     match /stories/{storyId}/likes/{userId} {
        allow read, write: if request.auth != null;
    }
    
     match /stories/{storyId}/ratings/{userId} {
        allow read, write: if request.auth != null;
    }
    
    match /posts/{postId}/comments/{commentId} {
        allow read, write: if request.auth != null;
    }
    
    match /teams/{teamId}/assignments/{assignmentId} {
        allow read, write: if request.auth != null;
    }
    
    match /exams/{examId}/answerSheets/{userId} {
        allow read, write: if request.auth != null;
    }
    
    match /exams/{examId}/results/{userId} {
        allow read, write: if request.auth != null;
    }
    
    match /users/{userId}/notifications/{notificationId} {
        allow read, write: if request.auth != null;
    }
    
    match /subjects/{subjectId}/trivia/{triviaId} {
        allow read, write: if request.auth != null;
    }
    
     match /subjects/{subjectId}/topics/{topicId}/lessons/{lessonId} {
        allow read, write: if request.auth != null;
    }
    
    match /subjects/{subjectId}/topics/{topicId}/lessons/{lessonId}/questions/{questionId} {
        allow read, write: if request.auth != null;
    }

    // Exam data if canReadExam(request.auth.uid, resource.data.school, resource.data.setBy);
match /exams/{examId} {
  // Allow reading (fetching exams) based on role and conditions
  allow read: if request.auth != null;
  allow write: if request.auth != null;
  
  // Allow creating exams for admins
  allow create: if isAdmin(request.auth.uid);
  
  // Allow updating exams based on role and type
  allow update: if isAuthorizedToUpdateExam(request.auth.uid, resource.data.examType);
  
  // Allow deleting exams based on role and subtype
  allow delete: if canDeleteExam(request.auth.uid, resource.data.examSubtype);

  // Function to check if a user can read an exam based on their role
//   function canReadExam(uid, examSchool, setBy) {
//     let role = get(/databases/$(database)/documents/users/$(uid)).data.role;
//     let userSchool = get(/databases/$(database)/documents/users/$(uid)).data.school;

//     return role == 'superAdmin' || // SuperAdmin can read all exams
//            (role == 'schoolAdmin' && examSchool == userSchool) || // SchoolAdmin can read exams for their school
//            ((role == 'teacherAdmin' || role == 'tuitionAdmin') && setBy == uid); // TeacherAdmin/TuitionAdmin can read their own exams
//   }

  // Function to check if a user is authorized to update an exam based on role and type
  function isAuthorizedToUpdateExam(uid, examType) {
    let role = get(/databases/$(database)/documents/users/$(uid)).data.role;
    return role == 'superAdmin' || 
           (role == 'tuitionAdmin' && examType == 'private') || 
           examType == 'school';
  }

  // Function to check if a user can delete an exam based on role and subtype
  function canDeleteExam(uid, examSubtype) {
    let role = get(/databases/$(database)/documents/users/$(uid)).data.role;
    return role == 'superAdmin' || 
           (role == 'tuitionAdmin' && examSubtype == 'private') || 
           examSubtype == 'school';
  }

  // Function to check if a user is an admin (used for create operation)
  function isAdmin(uid) {
    let role = get(/databases/$(database)/documents/users/$(uid)).data.role;
    return role == 'superAdmin' || 
           role == 'teacherAdmin' || 
           role == 'tuitionAdmin' || 
           role == 'schoolAdmin';
  }
}

match /subjects/{subjectId}/topics {
   allow read: if request.auth != null;
}

    // Subjects
    match /subjects/{subjectId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;

      // Only admins can create subjects
      allow create: if isAdmin(request.auth.uid);

      // Allow updates by admin, the subject creator, or editors
      allow update: if isAdmin(request.auth.uid) || 
                      isSubjectCreator(subjectId, request.auth.uid) || 
                      isEditor(subjectId, request.auth.uid);

      // Only superAdmin can delete subjects
      allow delete: if isSuperAdmin(request.auth.uid);

      // Function to check if the user is an admin
      function isAdmin(uid) {
        let role = get(/databases/$(database)/documents/users/$(uid)).data.role;
        return role == 'superAdmin' || 
               role == 'teacherAdmin' || 
               role == 'tuitionAdmin' || 
               role == 'schoolAdmin';
      }

      // Function to check if the user is a superAdmin
      function isSuperAdmin(uid) {
        return get(/databases/$(database)/documents/users/$(uid)).data.role == 'superAdmin';
      }

      // Function to check if the user is the creator of the subject
      function isSubjectCreator(subjectId, uid) {
        return get(/databases/$(database)/documents/subjects/$(subjectId)).data.creator == uid;
      }

      // Function to check if the user is an editor
      function isEditor(subjectId, uid) {
        let subjectData = get(/databases/$(database)/documents/subjects/$(subjectId)).data;
        return subjectData.editors.hasAny([uid]);
      }
      
      // Matching subcollections: topics, quizzes, lessons, and trivia
      match /topics/{topicId} {
        allow read, create, update, delete: if isAdmin(request.auth.uid) || request.auth != null ||
                                            isSubjectCreator(subjectId, request.auth.uid) || 
                                            isEditor(subjectId, request.auth.uid);
      }

      match /topics/{topicName}/quizzes/{quizId} {
        allow read, create, update, delete: if isAdmin(request.auth.uid) || request.auth != null || 
                                            isSubjectCreator(subjectId, request.auth.uid) || 
                                            isEditor(subjectId, request.auth.uid);
      }

      match /topics/{topicName}/lessons/{lessonTitle} {
        allow read, create, update, delete: if isAdmin(request.auth.uid) || 
                                            isSubjectCreator(subjectId, request.auth.uid) || 
                                            isEditor(subjectId, request.auth.uid);
      }

      match /topics/{topicName}/lessons/{lessonTitle}/questions/{questionId} {
        allow read, create, update, delete: if isAdmin(request.auth.uid) || 
                                            isSubjectCreator(subjectId, request.auth.uid) || 
                                            isEditor(subjectId, request.auth.uid);
      }

      match /trivia/{triviaId} {
        allow read, create, update, delete: if isAdmin(request.auth.uid) || 
                                            isSubjectCreator(subjectId, request.auth.uid) || 
                                            isEditor(subjectId, request.auth.uid);
      }
    }
     
    match /posts/{docId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update, delete: if request.auth.uid == resource.data.authorId;

        match /likes/{userId} {
          allow read: if request.auth != null;
          allow create, delete: if request.auth.uid == userId;
          allow read, write, create: if request.auth != null;
        }

        match /comments/{commentId} {
          allow read: if request.auth != null;
          allow create: if request.auth != null;
          allow delete: if request.auth.uid == resource.data.authorId;
        }

        match /comments/{commentId}/likes/{userId} {
          allow read: if request.auth != null;
          allow create, delete: if request.auth.uid == userId;
        }
      }
    
    // --- Teams Collection ---&& teamType == 'Peer'
match /teams/{teamId} {
  // Allow read if authorized (checking membership and role)
  allow read: if request.auth != null;//if isAuthorizedToReadTeam(resource.data);
  allow create: if request.auth != null;//if canCreateTeam(request.auth.uid, request.resource.data);
  allow update: if canUpdateTeam(request.auth.uid, resource.data, request.resource.data);
  allow delete: if canDeleteTeam(request.auth.uid, resource.data);
  allow write: if request.auth != null;

  // Function to check if the user is authorized to read the team
  function isAuthorizedToReadTeam(teamData) {
    let role = getUserRole(request.auth.uid);
    let school = getUserSchool(request.auth.uid);
    let teamType = teamData.teamType;

    return role == 'superAdmin' || 
           (role == 'schoolAdmin' && teamData.school == school) || 
           ((role == 'teacher' || role == 'parent' || role == 'student') && isMemberOfTeam(request.auth.uid, teamData.members)) || 
           (role == 'student' && teamType == 'Peer' && isMemberOfTeam(request.auth.uid, teamData.members)) || 
           ((role == 'student') && (teamType == 'Mwalimu' || teamType == 'Shule' || teamType == 'Darasa') && teamData.school == school && isMemberOfTeam(request.auth.uid, teamData.members)) || 
           ((role == 'teacherAdmin' || role == 'tuitionAdmin') && teamData.createdBy == request.auth.uid && teamData.school == school);
  }

  // We avoid using get() or exists() here by directly using teamData.members, which should be accessible.
  function isMemberOfTeam(uid, members) {
    return members.hasAny([uid]);
  }

  function canCreateTeam(uid, teamData) {
    let role = getUserRole(uid);
    let allowedTypes = {
      'superAdmin': ['Peer', 'Mwalimu', 'Shule', 'Darasa', 'Teachers', 'Office'],
      'teacherAdmin': ['Mwalimu', 'Darasa'],
      'tuitionAdmin': ['Mwalimu', 'Shule', 'Darasa'],
      'schoolAdmin': ['Mwalimu', 'Shule', 'Darasa', 'Teachers', 'Office'],
      'student': ['Peer']
    };
    return allowedTypes[role].hasAny([teamData.teamType]);
  }

  function canUpdateTeam(uid, currentTeamData, newTeamData) {
    let role = getUserRole(uid);
    let school = getUserSchool(uid);
    return (role == 'superAdmin' ? true : 
            (role == 'schoolAdmin' && currentTeamData.createdBy == uid && currentTeamData.school == school ? !hasRestrictedFields(newTeamData) : 
             (role == 'teacherAdmin' || role == 'tuitionAdmin') && currentTeamData.createdBy == uid ? !hasRestrictedFields(newTeamData) : 
             false));
  }

  function canDeleteTeam(uid, teamData) {
    let role = getUserRole(uid);
    let school = getUserSchool(uid);
    return role == 'superAdmin' || 
           (role == 'schoolAdmin' && teamData.createdBy == uid && teamData.school == school) || 
           (role == 'teacherAdmin' || role == 'tuitionAdmin' || role == 'student') && teamData.createdBy == uid;
  }

  function hasRestrictedFields(data) {
    return data.school != null || data.email != null || data.class != null;
  }
  
  match /assignments/{assignmentId} {
      allow read, write: if request.auth != null;
    }

    match /classes/{classId} {
      allow read, write: if request.auth != null;
    }

    match /chats/{chatId} {
      allow read, write: if request.auth != null;
    }
}


    // --- Team Limits ---
    match /teamLimits/{docId} {
      allow write: if isSuperAdmin(request.auth.uid);
      allow read: if request.auth != null;
    }
    
    
    //--- Team Chats ---
    match /teams/{teamId}/teamChats/{docId} {
      allow read, write: if canChatInTeam(request.auth.uid) || isAllowedAdmin(request.auth.uid);
      
      allow delete: if canDeleteTeamChat(request.auth.uid);
      
      function canChatInTeam(uid) {
  let role = getUserRole(uid);
  return (role == 'student' || role == 'teacher' || role == 'parent') ;
}

function isAllowedAdmin(uid) {
  let role = getUserRole(uid);
  let school = getUserSchool(uid);
  
  return role == 'superAdmin' || 
         (role == 'teacherAdmin' || role == 'tuitionAdmin') && 
         (isMemberOfTeam(uid, resource.data.teamId) || isSameSchoolAsUser(resource.data.teamId, uid)) || 
         (role == 'schoolAdmin' && isSameSchoolAsUser(resource.data.teamId, uid));
}

function canDeleteTeamChat(uid) {
  let role = getUserRole(uid);
  let teamType = getTeamType(resource.data.teamId);
  let school = getUserSchool(uid);

  return role == 'superAdmin' && (teamType != 'office' || isTeamCreator(uid, resource.data.teamId)) || 
         (role == 'teacherAdmin' || role == 'tuitionAdmin') && 
         (isTeamCreator(uid, resource.data.teamId) || (teamType == 'Peer' && isSameSchoolAsUser(resource.data.teamId, uid))) || 
         (resource.data.userId == uid);
}


      function getUserRole(uid) {
        return get(/databases/$(database)/documents/users/$(uid)).data.role;
      }

  function isMemberOfTeam(uid, members) {
    return members.hasAny([uid]);
  }


      function isSameSchoolAsUser(teamId, uid) {
        let userSchool = get(/databases/$(database)/documents/users/$(uid)).data.school;
        let teamSchool = get(/databases/$(database)/documents/teams/$(teamId)).data.school;
        return userSchool == teamSchool;
      }

      function isTeamCreator(uid, teamId) {
        let teamData = get(/databases/$(database)/documents/teams/$(teamId)).data;
        return teamData.creatorId == uid;
      }

      function getTeamType(teamId) {
        return get(/databases/$(database)/documents/teams/$(teamId)).data.teamType;
      }
    }

    // Helper functions for roles and permissions

    function isSuperAdmin(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role == 'superAdmin';
    }

    function getUserRole(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role;
    }

    function getUserSchool(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.school;
    }
    
  }
}
